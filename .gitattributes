# Force LF line endings for shell scripts (they run inside Docker/Linux)
*.sh text eol=lf
*.cmd text eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# Source code uses LF
*.c text eol=lf
*.h text eol=lf
*.py text eol=lf

# Makefiles must use LF
Makefile text eol=lf
